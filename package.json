{
  "name": "tollgate",
  "version": "0.1.0",
  "private": true,
  "description": "Bot-economics payment infrastructure on Arc. HTTP 402 + USDC + x402.",
  "license": "MIT",
  "author": "Brian Mwai",
  "homepage": "https://tollgate.brianmwai.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/brn-mwai/tollgate.git"
  },
  "packageManager": "pnpm@9.12.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm -C apps/dashboard dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "convex:dev": "convex dev --env-file apps/dashboard/.env.local",
    "convex:deploy": "convex deploy --env-file apps/dashboard/.env.local",
    "dashboard": "pnpm -C apps/dashboard dev"
  },
  "dependencies": {
    "@clerk/backend": "^1.21.0",
    "convex": "^1.31.0",
    "svix": "^1.45.0",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
