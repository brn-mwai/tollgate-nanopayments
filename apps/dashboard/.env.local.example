# ══════════════════════════════════════════════════════════════
# DAY 1 — minimum to boot the dashboard
# ══════════════════════════════════════════════════════════════

# Clerk (get from https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# Webhook signing secret (Clerk dashboard -> Webhooks -> your endpoint)
CLERK_WEBHOOK_SECRET=whsec_...

# Convex (auto-populated by `npx convex dev` on first run)
NEXT_PUBLIC_CONVEX_URL=https://....convex.cloud
# Only needed for CI
CONVEX_DEPLOY_KEY=

# ══════════════════════════════════════════════════════════════
# DAY 2 — Arc + Circle Wallets
# ══════════════════════════════════════════════════════════════

ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=
ARC_EXPLORER_URL=https://explorer.testnet.arc.network
ARC_USDC_CONTRACT=

CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
CIRCLE_WALLET_SET_ID=

# ══════════════════════════════════════════════════════════════
# DAY 3 — x402 facilitator + HMAC receipts + edge KV
# ══════════════════════════════════════════════════════════════

X402_FACILITATOR_URL=https://facilitator.x402.org
X402_FACILITATOR_NETWORK=arc-testnet

# 32+ byte random string for HMAC receipt signing
TOLLGATE_HMAC_SECRET=

# ══════════════════════════════════════════════════════════════
# DAY 4 — AIsa dogfood upstream
# ══════════════════════════════════════════════════════════════

AISA_API_KEY=

# ══════════════════════════════════════════════════════════════
# Demo (seeded via scripts/fund-demo-wallets.ts)
# ══════════════════════════════════════════════════════════════

DEMO_SITE_DOMAIN=demo-news.brianmwai.com
DEMO_PUBLISHER_WALLET_ADDRESS=
DEMO_AGENT_1_WALLET_ADDRESS=
DEMO_AGENT_2_WALLET_ADDRESS=
DEMO_AGENT_3_WALLET_ADDRESS=
